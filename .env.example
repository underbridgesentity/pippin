# Copy to `.env.local` and fill in to switch Fettle from local storage to a real
# Supabase backend (real auth, cloud sync, real global leaderboard).
# Leave these unset to keep the zero-setup local-storage mode.
# Find both values in your Supabase project: Settings → API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Social sign-in. Only list providers you have actually enabled in Supabase
# (Auth → Providers). The buttons stay hidden until listed here, so users never
# hit a dead OAuth journey. Example: VITE_AUTH_PROVIDERS=google
VITE_AUTH_PROVIDERS=
